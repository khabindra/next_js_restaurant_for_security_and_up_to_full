generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())

  @@map("contacts")
  @@index([createdAt(sort: Desc)]) // ⚡ Add this line
}


model Reservation {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  date      String   // YYYY-MM-DD
  time      String   // HH:mm
  guests    Int
  notes     String?
  status    String   @default("pending") // pending, confirmed, cancelled, completed
  createdAt DateTime @default(now())

  @@map("reservations")
  @@index([createdAt(sort: Desc)])
}




model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Int      // Storing price as an integer (e.g. Rs. 450)
  image       String?  // Public URL pointing to your Supabase storage bucket
  category    String   // starter, main, dessert, drink
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("menu_items")
  @@index([category])
}


model GalleryImage {
  id        String   @id @default(uuid())
  src       String   // Public URL pointing to your Supabase storage bucket
  alt       String
  category  String   @default("restaurant") // food, restaurant, event
  createdAt DateTime @default(now())

  @@map("gallery_images")
  @@index([category])              // ⚡ Essential for fast Public-side category tabs
  @@index([createdAt(sort: Desc)]) // ⚡ Essential for fast Admin-side sorting
}
